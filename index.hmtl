<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NLS // NoLimits System — NemorisHacking</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600;700&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
<style>
  :root {
    --black: #000;
    --bg: #080808;
    --bg2: #0f0f0f;
    --bg3: #161616;
    --bg4: #1e1e1e;
    --border: #2a2a2a;
    --border2: #3a3a3a;
    --white: #f0f0f0;
    --gray1: #999;
    --gray2: #666;
    --gray3: #444;
    --green: #00ff41;
    --green2: #00c832;
    --green3: #006616;
    --red: #ff3333;
    --accent: #c8c8c8;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: 'Share Tech Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* SCANLINE OVERLAY */
  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.05) 2px,
      rgba(0,0,0,0.05) 4px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* GLITCH KEYFRAMES */
  @keyframes glitch1 {
    0%,100% { clip-path: inset(0 0 100% 0); transform: translateX(0); }
    10% { clip-path: inset(10% 0 80% 0); transform: translateX(-4px); }
    20% { clip-path: inset(30% 0 60% 0); transform: translateX(4px); }
    30% { clip-path: inset(60% 0 20% 0); transform: translateX(-2px); }
    40% { clip-path: inset(80% 0 5% 0); transform: translateX(2px); }
  }
  @keyframes glitch2 {
    0%,100% { clip-path: inset(0 0 100% 0); transform: translateX(0); }
    15% { clip-path: inset(5% 0 85% 0); transform: translateX(5px); }
    25% { clip-path: inset(40% 0 40% 0); transform: translateX(-5px); }
    45% { clip-path: inset(70% 0 10% 0); transform: translateX(3px); }
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }
  @keyframes fadeInDown { from{opacity:0;transform:translateY(-20px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeInUp { from{opacity:0;transform:translateY(30px)} to{opacity:1;transform:translateY(0)} }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }
  @keyframes slideInLeft { from{opacity:0;transform:translateX(-40px)} to{opacity:1;transform:translateX(0)} }
  @keyframes slideInRight { from{opacity:0;transform:translateX(40px)} to{opacity:1;transform:translateX(0)} }
  @keyframes typewriter { from{width:0} to{width:100%} }
  @keyframes scanline {
    0% { top: -10%; }
    100% { top: 110%; }
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  @keyframes countUp { from{opacity:0;transform:scale(0.8)} to{opacity:1;transform:scale(1)} }
  @keyframes borderGlow {
    0%,100% { border-color: var(--border2); }
    50% { border-color: var(--gray1); }
  }
  @keyframes matrixRain {
    0% { transform: translateY(-100%); opacity: 1; }
    100% { transform: translateY(100vh); opacity: 0; }
  }
  @keyframes terminalBlink {
    0%,49%{border-right-color:var(--green)} 50%,100%{border-right-color:transparent}
  }

  /* MATRIX BG */
  #matrix-bg {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.03;
    overflow: hidden;
    font-size: 12px;
    font-family: 'Share Tech Mono', monospace;
    color: #fff;
  }
  .matrix-col {
    position: absolute;
    top: 0;
    writing-mode: vertical-rl;
    animation: matrixRain linear infinite;
    white-space: nowrap;
    letter-spacing: 4px;
  }

  /* LAYOUT */
  .wrapper { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  /* TOP BAR */
  .topbar {
    background: var(--black);
    border-bottom: 1px solid var(--border);
    padding: 8px 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .topbar .wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .topbar-left {
    font-size: 11px;
    color: var(--gray2);
    letter-spacing: 2px;
  }
  .topbar-left span { color: var(--green); }
  .topbar-right {
    display: flex;
    gap: 20px;
    font-size: 11px;
    color: var(--gray2);
    letter-spacing: 1px;
  }
  .topbar-right a { color: var(--gray2); text-decoration: none; transition: color 0.2s; }
  .topbar-right a:hover { color: var(--white); }

  /* HERO */
  .hero {
    padding: 60px 0 40px;
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .hero::after {
    content: '';
    position: absolute;
    left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gray3), transparent);
    bottom: 0;
  }

  .hero-terminal {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-radius: 4px;
    margin-bottom: 32px;
    animation: fadeInDown 0.6s ease;
  }
  .terminal-bar {
    background: var(--bg3);
    padding: 8px 14px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
    border-radius: 4px 4px 0 0;
  }
  .terminal-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    background: var(--gray3);
  }
  .terminal-dot.red { background: #3a1a1a; }
  .terminal-dot.yellow { background: #2a2a1a; }
  .terminal-dot.green { background: var(--green3); }
  .terminal-title { color: var(--gray2); font-size: 11px; margin-left: auto; letter-spacing: 1px; }
  .terminal-body { padding: 20px 24px; font-size: 13px; line-height: 2; }
  .terminal-line { display: flex; align-items: baseline; gap: 8px; }
  .prompt { color: var(--green); }
  .cmd { color: var(--white); }
  .terminal-output { color: var(--gray1); padding-left: 16px; }
  .terminal-cursor {
    display: inline-block;
    width: 8px; height: 15px;
    background: var(--green);
    animation: blink 1s step-end infinite;
    vertical-align: -2px;
    margin-left: 2px;
  }

  .hero-logo {
    text-align: center;
    margin-bottom: 16px;
    animation: fadeIn 0.8s ease 0.3s both;
  }
  .logo-main {
    font-family: 'Orbitron', monospace;
    font-size: 52px;
    font-weight: 900;
    color: var(--white);
    letter-spacing: 6px;
    position: relative;
    display: inline-block;
  }
  .logo-main::before, .logo-main::after {
    content: 'NLS';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
  }
  .logo-main::before { color: rgba(255,255,255,0.08); animation: glitch1 4s infinite; }
  .logo-main::after { color: rgba(255,255,255,0.05); animation: glitch2 4s infinite 0.5s; }

  .logo-sub {
    font-family: 'Rajdhani', sans-serif;
    font-size: 13px;
    font-weight: 300;
    letter-spacing: 8px;
    color: var(--gray2);
    text-transform: uppercase;
    margin-top: 4px;
  }
  .logo-sub span { color: var(--gray1); }

  .hero-tagline {
    text-align: center;
    font-size: 11px;
    color: var(--gray2);
    letter-spacing: 3px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 12px 0;
    margin: 24px 0;
    animation: fadeIn 1s ease 0.6s both;
  }

  /* NAV */
  .nav {
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 37px;
    z-index: 99;
  }
  .nav .wrapper {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .nav-item {
    padding: 14px 20px;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--gray2);
    text-transform: uppercase;
    cursor: pointer;
    border-right: 1px solid var(--border);
    white-space: nowrap;
    transition: all 0.2s;
    text-decoration: none;
    display: block;
  }
  .nav-item:hover { color: var(--white); background: var(--bg3); }
  .nav-item.active { color: var(--white); background: var(--bg3); border-bottom: 2px solid var(--white); }

  /* MAIN GRID */
  .main-grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 0;
    min-height: 100vh;
    border-left: 1px solid var(--border);
    border-right: 1px solid var(--border);
  }

  /* FEED */
  .feed { border-right: 1px solid var(--border); }

  .section-header {
    padding: 16px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--bg2);
  }
  .section-header h2 {
    font-family: 'Rajdhani', sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--white);
  }
  .section-badge {
    background: var(--bg4);
    border: 1px solid var(--border2);
    color: var(--gray1);
    font-size: 10px;
    padding: 2px 8px;
    letter-spacing: 1px;
  }

  /* POST CARD */
  .post {
    border-bottom: 1px solid var(--border);
    padding: 20px;
    transition: background 0.15s;
    animation: fadeInUp 0.5s ease both;
    cursor: pointer;
  }
  .post:hover { background: var(--bg2); }
  .post:nth-child(1) { animation-delay: 0.1s; }
  .post:nth-child(2) { animation-delay: 0.2s; }
  .post:nth-child(3) { animation-delay: 0.3s; }
  .post:nth-child(4) { animation-delay: 0.4s; }
  .post:nth-child(5) { animation-delay: 0.5s; }

  .post-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }
  .post-avatar {
    width: 32px; height: 32px;
    background: var(--bg4);
    border: 1px solid var(--border2);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    color: var(--gray1);
    flex-shrink: 0;
    font-family: 'Orbitron', monospace;
  }
  .post-meta { flex: 1; }
  .post-author {
    font-size: 12px;
    color: var(--white);
    letter-spacing: 1px;
  }
  .post-author span { color: var(--green); }
  .post-time {
    font-size: 10px;
    color: var(--gray2);
    letter-spacing: 1px;
    margin-top: 2px;
  }

  .post-category {
    font-size: 9px;
    letter-spacing: 2px;
    padding: 3px 8px;
    border: 1px solid var(--border2);
    color: var(--gray2);
    text-transform: uppercase;
  }
  .post-category.red { border-color: #3a1a1a; color: var(--red); }
  .post-category.green { border-color: var(--green3); color: var(--green2); }
  .post-category.white { border-color: var(--border2); color: var(--gray1); }

  .post-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 8px;
    line-height: 1.3;
    letter-spacing: 0.5px;
  }
  .post-excerpt {
    font-size: 11px;
    color: var(--gray1);
    line-height: 1.7;
    margin-bottom: 12px;
  }
  .post-footer {
    display: flex;
    gap: 20px;
    font-size: 10px;
    color: var(--gray2);
    letter-spacing: 1px;
    align-items: center;
  }
  .post-footer-item { display: flex; gap: 6px; align-items: center; }
  .post-link {
    margin-left: auto;
    color: var(--gray2);
    text-decoration: none;
    font-size: 10px;
    letter-spacing: 1px;
    border: 1px solid var(--border);
    padding: 4px 10px;
    transition: all 0.2s;
  }
  .post-link:hover { color: var(--white); border-color: var(--gray2); }

  /* SIDEBAR */
  .sidebar {}

  .sidebar-block {
    border-bottom: 1px solid var(--border);
    animation: slideInRight 0.5s ease both;
  }
  .sidebar-block:nth-child(1) { animation-delay: 0.2s; }
  .sidebar-block:nth-child(2) { animation-delay: 0.35s; }
  .sidebar-block:nth-child(3) { animation-delay: 0.5s; }

  .sidebar-body { padding: 16px 18px; }

  /* PROFILE CARD */
  .profile-card { padding: 20px 18px; }
  .profile-avatar-wrap { margin-bottom: 16px; text-align: center; }
  .profile-avatar {
    width: 72px; height: 72px;
    background: var(--bg4);
    border: 1px solid var(--border2);
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Orbitron', monospace;
    font-size: 18px;
    font-weight: 700;
    color: var(--white);
    position: relative;
    animation: borderGlow 3s ease infinite;
  }
  .profile-avatar::before {
    content: '';
    position: absolute;
    inset: -4px;
    border: 1px solid var(--border);
  }
  .profile-name {
    font-family: 'Orbitron', monospace;
    font-size: 14px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 2px;
    margin-bottom: 2px;
    text-align: center;
  }
  .profile-handle {
    font-size: 10px;
    color: var(--green);
    text-align: center;
    letter-spacing: 2px;
    margin-bottom: 12px;
  }
  .profile-bio {
    font-size: 10px;
    color: var(--gray1);
    line-height: 1.8;
    text-align: center;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    margin-bottom: 14px;
  }
  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    justify-content: center;
    margin-bottom: 16px;
  }
  .tag {
    font-size: 9px;
    letter-spacing: 1px;
    padding: 3px 8px;
    border: 1px solid var(--border2);
    color: var(--gray2);
    text-transform: uppercase;
  }
  .tag.active { border-color: var(--gray1); color: var(--gray1); }

  .profile-links { display: flex; flex-direction: column; gap: 8px; }
  .profile-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border: 1px solid var(--border);
    text-decoration: none;
    color: var(--gray1);
    font-size: 10px;
    letter-spacing: 1px;
    transition: all 0.2s;
  }
  .profile-link:hover { background: var(--bg3); border-color: var(--border2); color: var(--white); }
  .profile-link-icon { font-size: 12px; color: var(--gray2); width: 16px; text-align: center; }

  /* STATS */
  .stat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); margin: 0; }
  .stat-item {
    background: var(--bg);
    padding: 16px 14px;
    text-align: center;
  }
  .stat-num {
    font-family: 'Orbitron', monospace;
    font-size: 22px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 1px;
    animation: countUp 0.8s ease both;
  }
  .stat-label {
    font-size: 9px;
    color: var(--gray2);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 4px;
  }

  /* ACHIEVEMENTS */
  .achievement {
    padding: 10px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 10px;
    align-items: flex-start;
  }
  .achievement:last-child { border-bottom: none; }
  .achievement-icon { color: var(--gray2); font-size: 12px; margin-top: 2px; flex-shrink: 0; }
  .achievement-title { font-size: 11px; color: var(--white); margin-bottom: 3px; letter-spacing: 0.5px; }
  .achievement-meta { font-size: 9px; color: var(--gray2); letter-spacing: 1px; }

  /* PRESS FEED */
  .press-item {
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }
  .press-item:last-child { border-bottom: none; }
  .press-num { font-size: 11px; color: var(--gray3); width: 18px; flex-shrink: 0; padding-top: 1px; }
  .press-content { flex: 1; }
  .press-title { font-size: 11px; color: var(--white); margin-bottom: 4px; line-height: 1.4; text-decoration: none; display: block; }
  .press-title:hover { color: var(--gray1); }
  .press-source { font-size: 9px; color: var(--gray2); letter-spacing: 1px; }

  /* MEDIA GRID */
  .media-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); }
  .media-item {
    background: var(--bg);
    padding: 12px;
    text-decoration: none;
    display: block;
    transition: background 0.15s;
  }
  .media-item:hover { background: var(--bg3); }
  .media-platform { font-size: 9px; color: var(--gray2); letter-spacing: 2px; text-transform: uppercase; margin-bottom: 4px; }
  .media-handle { font-size: 11px; color: var(--white); }

  /* TICKER */
  .ticker-wrap {
    background: var(--black);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 8px 0;
    overflow: hidden;
    position: relative;
  }
  .ticker {
    display: flex;
    gap: 0;
    white-space: nowrap;
    animation: ticker 25s linear infinite;
  }
  @keyframes ticker {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .ticker-item {
    padding: 0 24px;
    font-size: 10px;
    color: var(--gray2);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .ticker-item span { color: var(--white); }
  .ticker-sep { color: var(--gray3); }

  /* ALERT BANNER */
  .alert-banner {
    background: var(--bg2);
    border: 1px solid var(--border2);
    border-left: 3px solid var(--white);
    padding: 12px 16px;
    margin: 20px;
    display: flex;
    gap: 12px;
    align-items: center;
    animation: fadeIn 1s ease 0.8s both;
  }
  .alert-icon { font-size: 14px; color: var(--gray1); }
  .alert-text { font-size: 11px; color: var(--gray1); line-height: 1.6; }
  .alert-text strong { color: var(--white); }

  /* FOOTER */
  footer {
    border-top: 1px solid var(--border);
    background: var(--black);
    padding: 30px 0;
    margin-top: 0;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 24px;
  }
  .footer-col-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--gray2);
    border-bottom: 1px solid var(--border);
    padding-bottom: 10px;
    margin-bottom: 14px;
  }
  .footer-link {
    display: block;
    font-size: 11px;
    color: var(--gray2);
    text-decoration: none;
    padding: 4px 0;
    letter-spacing: 1px;
    transition: color 0.2s;
  }
  .footer-link:hover { color: var(--white); }
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 16px;
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    color: var(--gray3);
    letter-spacing: 1px;
  }
  .footer-bottom span { color: var(--gray2); }

  /* STATUS */
  .status-dot {
    display: inline-block;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--green);
    animation: pulse 2s ease infinite;
    margin-right: 6px;
  }

  /* VECERT BADGE */
  .vecert-badge {
    background: var(--bg4);
    border: 1px solid var(--border2);
    padding: 14px;
    margin-bottom: 1px;
    text-align: center;
  }
  .vecert-label { font-size: 9px; color: var(--gray2); letter-spacing: 3px; text-transform: uppercase; margin-bottom: 8px; }
  .vecert-rank {
    font-family: 'Orbitron', monospace;
    font-size: 28px;
    font-weight: 900;
    color: var(--white);
    letter-spacing: 2px;
  }
  .vecert-sub { font-size: 10px; color: var(--gray2); letter-spacing: 1px; margin-top: 4px; }

  @media (max-width: 900px) {
    .main-grid { grid-template-columns: 1fr; }
    .sidebar { border-top: 1px solid var(--border); }
    .footer-grid { grid-template-columns: 1fr; }
    .logo-main { font-size: 36px; }
  }
</style>
</head>
<body>

<!-- Matrix Background -->
<div id="matrix-bg"></div>

<!-- TOP BAR -->
<div class="topbar">
  <div class="wrapper">
    <div class="topbar-left">
      <span>■</span> NLS // NoLimits System — <span>ONLINE</span>
    </div>
    <div class="topbar-right">
      <span><span class="status-dot"></span>ACTIVE</span>
      <a href="https://t.me/NLS_ChatGeneral" target="_blank">CHAT</a>
      <a href="https://github.com/NLS-BlackHat" target="_blank">GITHUB</a>
      <a href="https://t.me/NemorisHacking" target="_blank">CANAL</a>
    </div>
  </div>
</div>

<!-- TICKER -->
<div class="ticker-wrap">
  <div class="ticker" id="ticker">
